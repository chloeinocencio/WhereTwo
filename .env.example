# AviationStack API key — used for flight number lookup in the itinerary view.
# Sign up free at https://aviationstack.com (100 req/month on free plan).
# Note: HTTPS support requires a paid plan; on the free plan lookups work in
# local dev (http) but may be blocked in a production HTTPS deployment.
VITE_AVIATIONSTACK_KEY=your_key_here
